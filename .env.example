# Brain-Inspired RAG Configuration
#
# This file is safe to commit. Copy it to `.env` for local overrides.
# Keep real API keys, private paths, and credentials out of Git.

# Application Settings
APP_NAME=Brain-Inspired RAG
APP_VERSION=1.0.0
DEBUG=False

# Qdrant Configuration
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=
QDRANT_TIMEOUT=60

# Collection Configuration
DEFAULT_COLLECTION_NAME=brain_rag_collection
DENSE_VECTOR_SIZE=384

# CORS
# Comma-separated list. Keep this local unless you add auth and deployment hardening.
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Inference backend: mlx (default; Apple-Silicon /query RAG path) or gguf (cross-platform direct/batch)
INFERENCE_BACKEND=mlx

# MLX Configuration (Apple Silicon native LLM runtime)
MLX_MODEL_CACHE_DIR=~/.cache/mlx-lm
MLX_WARMUP_ON_LOAD=True
MLX_METAL_CLEAR_CACHE_BETWEEN_PROFILES=True

# Model Selection - mlx-community models for Apple Silicon
# Available profiles:
# - fast: mlx-community/Qwen3.5-4B-MLX-4bit, 400 token cap, thinking off [DEFAULT]
# - balanced: same model, 600 token cap, thinking off
# - quality: same model, 800 token cap, thinking on
MODEL_PROFILE=fast
# Optional: Override with any mlx-community model ID
CUSTOM_MODEL_NAME=
REPETITION_PENALTY=1.15

# Embedding Models
DENSE_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
SPARSE_MODEL_NAME=Qdrant/bm25
SPARSE_STRATEGY=bm25

# Document Processing
CHUNK_SIZE=512
CHUNK_OVERLAP=128
MAX_FILE_SIZE_MB=50
BATCH_SIZE=32
MAX_WORKERS=4

# Retrieval Configuration
RETRIEVAL_STRATEGY=dense
FUSION_METHOD=rrf
HYBRID_FUSION_METHOD=rrf
TOP_K_RESULTS=10
DENSE_WEIGHT=0.5
SPARSE_WEIGHT=0.5
RETRIEVAL_SCORE_THRESHOLD=0.5

# Reranking / salience layer
RERANK_ENABLED=False
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_TOP_K=5
DIVERSIFY_SOURCES=True

# Brain Module Weights (Amygdala)
RECENCY_WEIGHT=0.3
RELEVANCE_WEIGHT=0.5
IMPORTANCE_WEIGHT=0.2

# Working Memory
CONTEXT_WINDOW_SIZE=5
MAX_CONVERSATION_HISTORY=10

# Local tuning outputs and KV cache. These paths are gitignored.
BENCHMARK_OUTPUT_DIR=app/tuning/results
KV_CACHE_DIR=.cache/kv
KV_MAX_SESSIONS=3
KV_MAX_MB_PER_FILE=50
ENGINE_WARMUP=True
TEMPERATURE=0.1

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=<green>{time:YYYY-MM-DD HH:mm:ss}</green> | <level>{level: <8}</level> | <cyan>{name}</cyan>:<cyan>{function}</cyan> - <level>{message}</level>
