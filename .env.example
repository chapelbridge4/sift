# Brain-Inspired RAG Configuration

# Application Settings
APP_NAME=Brain-Inspired RAG
APP_VERSION=1.0.0
DEBUG=False

# Qdrant Configuration
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=
QDRANT_TIMEOUT=60

# Collection Configuration
DEFAULT_COLLECTION_NAME=brain_rag_collection
DENSE_VECTOR_SIZE=384

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT=120

# Model Selection (NEW - Optimized for M1)
# Available profiles: fast, balanced, quality, reasoning
# - fast: qwen2.5:0.5b (~40-50 tokens/s) - Ultra-fast responses
# - balanced: qwen2.5:1.5b (~30-40 tokens/s) - Best speed/quality balance [DEFAULT]
# - quality: qwen2.5:3b (~20-30 tokens/s) - Higher quality
# - reasoning: qwen3:3b (~15-25 tokens/s) - Step-by-step reasoning
MODEL_PROFILE=balanced
# Optional: Override with specific model name (e.g., qwen2.5:7b)
CUSTOM_MODEL_NAME=

# Embedding Models
DENSE_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
SPARSE_MODEL_NAME=Qdrant/bm25

# Document Processing
CHUNK_SIZE=512
CHUNK_OVERLAP=128
MAX_FILE_SIZE_MB=50
BATCH_SIZE=32
MAX_WORKERS=4

# Hybrid Search Configuration
HYBRID_FUSION_METHOD=rrf
TOP_K_RESULTS=10
DENSE_WEIGHT=0.5
SPARSE_WEIGHT=0.5

# Brain Module Weights (Amygdala)
RECENCY_WEIGHT=0.3
RELEVANCE_WEIGHT=0.5
IMPORTANCE_WEIGHT=0.2

# Working Memory
CONTEXT_WINDOW_SIZE=5
MAX_CONVERSATION_HISTORY=10

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=<green>{time:YYYY-MM-DD HH:mm:ss}</green> | <level>{level: <8}</level> | <cyan>{name}</cyan>:<cyan>{function}</cyan> - <level>{message}</level>
